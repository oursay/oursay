---
const values = [
  { word: "Transparency", body: "Everything OurSay does is open source and out in the open — including the code that runs it." },
  { word: "Accountability", body: "A permanent, auditable record of what people said, that representatives can be held to." },
  { word: "Your Say", body: "The right to make your voice known — clearly, verifiably, and without asking permission." },
];
---

<section class="bg-brand-700 text-white">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl">
        Built on values both sides of the aisle can share
      </h2>
      <p class="mt-5 text-pretty text-lg leading-relaxed text-brand-100">
        OurSay carries no party and no agenda. It works for any system where the
        goal is to give power to the people — and it earns its place by being
        something anyone can inspect, question, and verify.
      </p>
    </div>

    <dl class="mt-14 grid gap-8 sm:grid-cols-3">
      {
        values.map((v) => (
          <div class="text-center">
            <dt class="text-xl font-bold text-white">{v.word}</dt>
            <dd class="mt-2 text-sm leading-relaxed text-brand-100">{v.body}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
