---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import { navLinks, site } from "../data/site";
import { forms } from "../data/forms";
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/70 bg-paper/85 backdrop-blur supports-[backdrop-filter]:bg-paper/70"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <Logo />

    <div class="hidden items-center gap-7 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-slate-600 transition-colors hover:text-brand-700"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3">
      <a
        href={site.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-sm font-medium text-slate-600 hover:text-brand-700 sm:inline"
        >GitHub</a
      >
      <Button href={forms.waitlist.url} external class="!px-5 !py-2">
        Join the waitlist
      </Button>

      <!-- Mobile menu (no-JS disclosure) -->
      <details class="relative md:hidden">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-md text-slate-700 hover:bg-slate-100"
          aria-label="Open menu"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
          </svg>
        </summary>
        <div
          class="absolute right-0 mt-2 w-52 rounded-xl border border-slate-200 bg-white p-2 shadow-lg"
        >
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-brand-50 hover:text-brand-700"
              >
                {link.label}
              </a>
            ))
          }
          <a
            href={site.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-brand-50 hover:text-brand-700"
            >GitHub</a
          >
        </div>
      </details>
    </div>
  </nav>
</header>
