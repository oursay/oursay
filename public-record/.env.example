# public-record configuration. Copy to .env (gitignored) to override defaults.
# Defaults below match docker-compose.yml, so the tests run with NO .env at all.

# --- immudb 1.11.0 over the PostgreSQL wire protocol (public append-only chain) ---
IMMUDB_PG_HOST=127.0.0.1
IMMUDB_PG_PORT=5443
IMMUDB_PG_USER=immudb
IMMUDB_PG_PASSWORD=immudb
IMMUDB_PG_DATABASE=defaultdb

# --- Postgres (private mutable store: record_tx event log + raw content + salt) ---
PGHOST=127.0.0.1
PGPORT=5442
PGUSER=oursay
PGPASSWORD=oursay
PGDATABASE=oursay_public_record
