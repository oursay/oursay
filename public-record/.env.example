# public-record configuration. Copy to .env (gitignored) to override defaults.
# Defaults below match docker-compose.yml, so the tests run with NO .env at all.

# --- immudb 1.11.0 over the PostgreSQL wire protocol (public append-only chain) ---
IMMUDB_PG_HOST=127.0.0.1
IMMUDB_PG_PORT=5443
IMMUDB_PG_USER=immudb
IMMUDB_PG_PASSWORD=immudb
IMMUDB_PG_DATABASE=defaultdb

# --- Postgres (private mutable store: record_tx event log + raw content + salt) ---
PGHOST=127.0.0.1
PGPORT=5442
PGUSER=oursay
PGPASSWORD=oursay
PGDATABASE=oursay_public_record

# --- Settlement retry policy (default "3-3-3"); a count of 0 means INDEFINITE ---
# Applied when a block's batch append to immudb fails. If immudb is healthy, retry this many times.
OUTBOX_RETRY_ATTEMPTS=3
# If immudb is down, wait this many MINUTES between healthchecks (0 = no delay).
OUTBOX_HEALTHCHECK_WAIT_MINUTES=3
# If immudb is down, give up after this many healthchecks (0 = re-check forever).
OUTBOX_HEALTHCHECK_ATTEMPTS=3

# --- Chain identity (genesis/network id) ---
# Block headers are keyed by (CHAIN_ID, block_height). immudb is append-only and never reset, so a
# stable id per deployment keeps a single growing chain; tests/seed use a fresh id per run. This is the
# public-record library/seed default (the universal record); the API has its OWN civic CHAIN_ID default
# (ab-ca-gov, the launch jurisdiction), and the settlement worker uses WORKER_CHAIN_IDS (below).
CHAIN_ID=oursay-global

# --- Block settlement trigger (pool → append-only chain) ---
# Settle a block once this many txs are pending (0 = disable the count trigger).
BLOCK_MAX_PENDING=250
# …or once the OLDEST pending tx has waited this many HOURS (0 = disable the age trigger). This is
# an operational cadence trigger only — it decides WHEN to cut a block, never transaction order.
BLOCK_MAX_PENDING_AGE_HOURS=12
# Hard cap on txs per settled block (a larger backlog settles across several blocks).
BLOCK_MAX_TXS=250
# Minimum pending txs to settle (clamped to >= 1, so an empty block is never settled).
BLOCK_MIN_TXS=1

# --- External anchor publish cadence (settled chain → target) ---
# The file target publishes every N settled blocks (still in order, no gaps).
FILE_ANCHOR_EVERY_BLOCKS=2

# --- Settlement worker (scripts/worker.ts: pool → settle → anchor, for a SET of chains) ---
# The chains this worker settles + anchors: every supported chain — `oursay-global` (the universal
# record) + `ab-ca-gov` (the launch jurisdiction). `ab-ca-gov` is the API's civic CHAIN_ID, so
# `npm run dev -w @oursay/api` + `npm run worker -w public-record` settle the same pool with no extra
# config; `oursay-global` is on by default and simply has no writer yet (settling an empty chain is a
# cheap no-op — minTxs >= 1 never settles empty). Run EXACTLY ONE worker per chain (single-proposer).
WORKER_CHAIN_IDS=oursay-global,ab-ca-gov
# Polling floor: wake at least this often (ms) to re-check the COUNT trigger between writes (the
# stand-in for a future Postgres LISTEN/NOTIFY). The worker otherwise sleeps until the next age deadline.
WORKER_MAX_IDLE_MS=60000
# Busy-loop ceiling: never sleep less than this (ms) between ticks.
WORKER_MIN_INTERVAL_MS=1000
# Base directory for file anchors; each chain writes to <FILE_ANCHOR_DIR>/<chainId>/ (anchors.jsonl +
# blocks/). Default ./.anchors resolves to public-record/.anchors/ (gitignored).
FILE_ANCHOR_DIR=./.anchors
# Per-chain settlement overrides (optional): suffix any BLOCK_* / FILE_ANCHOR_EVERY_BLOCKS var with the
# chain id sanitized to UPPER_SNAKE, e.g. BLOCK_MAX_PENDING__AB_CA_GOV=50 or FILE_ANCHOR_EVERY_BLOCKS__OURSAY_GLOBAL=1.
# Absent an override, a chain uses the global BLOCK_* / FILE_ANCHOR_EVERY_BLOCKS values above.

# --- Identity: platform registration-binding signing key (Track A) ---
# The platform signs each per-thread registration binding with this P-256 key (hex private key);
# the verified-tier append gate (RecordService.appendSigned) re-verifies binding_sig against it.
# ENV-REQUIRED with NO default and NO committed value (VALUES §9: no secrets in git). The test suite
# generates an EPHEMERAL key per run, so `npm test` needs nothing set here. KMS-managed keys are a
# later milestone. Generate a dev key, e.g.:
#   node -e "import('@noble/curves/p256').then(({p256})=>import('@noble/hashes/utils').then(({bytesToHex})=>console.log(bytesToHex(p256.utils.randomPrivateKey()))))"
# PLATFORM_BINDING_PRIVKEY=

# --- Signed-envelope freshness gate (appendSigned) ---
# Reject a signed envelope at commit when serverNow - createdAt exceeds this many seconds. 0 DISABLES
# the gate (today's behavior: no rejection). Default 120 (dev). createdAt is already in the signing
# digest, so this needs no envelope/wire change. NOTE: clients must set createdAt at SIGN time (not at
# prepareAppend time) so the age reflects the signature, not the prepare round-trip.
SIGNED_ENVELOPE_MAX_AGE_SEC=120
# Tolerance for a slightly-fast client clock: an envelope whose createdAt is ahead of server time by
# at most this many seconds is accepted; beyond it is rejected as clock skew.
SIGNED_ENVELOPE_FUTURE_SKEW_SEC=60
