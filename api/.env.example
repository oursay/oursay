# @oursay/api environment. Copy to .env (git-ignored) and adjust. No secrets are committed.
# Values fall back to dev-safe defaults; production MUST set SESSION_SECRET and real mailer creds.

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ── Postgres (SHARED with @oursay/public-record; defaults match its docker-compose) ──
# @oursay/api adds its `auth` schema to this database and FKs public.users.
PGHOST=127.0.0.1
PGPORT=5442
PGUSER=oursay
PGPASSWORD=oursay
PGDATABASE=oursay_public_record

# ── Sessions (opaque DB-backed tokens) ───────────────────────────────────────
# SESSION_SECRET is a server-side pepper mixed into OTP + token hashes. REQUIRED in production.
SESSION_SECRET=dev-insecure-session-pepper-change-me
SESSION_TTL_SEC=2592000
SESSION_COOKIE_NAME=oursay_session
# Secure cookie flag; auto-on under NODE_ENV=production. Keep false for http://localhost.
SESSION_COOKIE_SECURE=false

# ── Email OTP + rate limits ───────────────────────────────────────────────────
# OTP serves three purposes (docs/08): registration (bootstrap), recovery (lost passkey), and the
# gated cross-device login. OTP_TTL_SEC also bounds the login enable window (no separate TTL).
OTP_LENGTH=6
OTP_TTL_SEC=600
OTP_MAX_ATTEMPTS=5
RL_OTP_REQUEST_PER_HOUR=5
RL_OTP_REQUEST_PER_IP_PER_HOUR=20
RL_OTP_WINDOW_SEC=3600

# ── Registration ──────────────────────────────────────────────────────────────
MIN_AGE_YEARS=18

# ── Geocoding (best-effort address -> private point; structural resolvability, NOT KYC) ──
# Registration NEVER fails because of geocoding; the derived point is PRIVATE PII (auth.profile_geocodes)
# and is never returned on any HTTP response. Provider:
#   stub     - deterministic, no network, no key (default; used by CI/dev). Resolves only CA postal codes.
#   geocodio - real provider (https://www.geocod.io); set GEOCODE_API_KEY. Canada-capable.
#   nominatim - RESERVED, NOT IMPLEMENTED: selecting it fails fast at startup. A self-hosted Nominatim is
#               future work (no public nominatim.openstreetmap.org in prod; ODbL attribution required).
GEOCODE_PROVIDER=stub
GEOCODE_API_KEY=
GEOCODE_TIMEOUT_MS=5000
# Reserved for a future self-hosted Nominatim provider (unused today):
# GEOCODE_NOMINATIM_URL=http://localhost:8088

# ── WebAuthn (passkey) relying party ─────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=OurSay
WEBAUTHN_ORIGIN=http://localhost:8080
# Require the authenticator user-verification flag (biometric/PIN). Forced ON under
# NODE_ENV=production (this value is ignored there); set false only for dev/test authenticators.
WEBAUTHN_REQUIRE_UV=true

# ── Civic record engine + launch jurisdiction (civic write routes) ────────────
# PLATFORM_BINDING_PRIVKEY is the platform's P-256 key (hex) that signs each thread registration
# binding (and whose public key verifies them at submit). REQUIRED in production (no committed
# secret); a dev-insecure default is used otherwise. Tests inject an ephemeral key per run.
PLATFORM_BINDING_PRIVKEY=
# Reject a signed envelope at submit when serverNow - createdAt exceeds this many seconds (0 disables).
SIGNED_ENVELOPE_MAX_AGE_SEC=120
# Ledger partition id for the civic chain (one chain per jurisdiction at launch).
CHAIN_ID=ab-ca-gov
# Launch jurisdiction (docs/GLOSSARY). Generic by design — all env-overridable. Default governance is
# FINAL-action: votes/signatures are final unless an entity opts in. Product label: post -> "Belief".
JURISDICTION_ID=ab-ca-gov
JURISDICTION_LEVEL=provincial
JURISDICTION_ALLOW_CHANGE=false
JURISDICTION_ALLOW_REVOKE=false

# ── Mailer (role -> ordered adapters: primary,failover). Vendors: postmark|smtp|ses|noop ──
# noop: no delivery; in non-production the dev server console prints OTP codes for manual walks.
MAILER_FROM=OurSay <no-reply@oursay.ca>
MAILER_REGISTRATION_VENDORS=noop
MAILER_RECOVERY_VENDORS=noop
MAILER_LOGIN_VENDORS=noop

# Postmark (default vendor)
POSTMARK_TOKEN=

# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# AWS SES v2
SES_REGION=us-east-1
