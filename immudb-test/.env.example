# immudb-test configuration. Copy to .env (gitignored) to override defaults.
# Defaults below match docker-compose.yml, so the tests run with NO .env at all.

# --- immudb (public verifiable ledger) ---
IMMUDB_HOST=127.0.0.1
IMMUDB_PORT=3322
IMMUDB_USER=immudb
IMMUDB_PASSWORD=immudb
IMMUDB_DATABASE=defaultdb

# --- immudb 1.11.0 over the PostgreSQL wire protocol (modern "reach up" path) ---
IMMUDB_PG_HOST=127.0.0.1
IMMUDB_PG_PORT=5433
IMMUDB_PG_USER=immudb
IMMUDB_PG_PASSWORD=immudb
IMMUDB_PG_DATABASE=defaultdb

# --- Postgres (private mutable store: users, keys, raw content) ---
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=oursay
PGPASSWORD=oursay
PGDATABASE=oursay_private

# --- Anchoring ---
# Named docker volume holding immudb data (used by the @physical tamper test).
IMMUDB_DATA_VOLUME=oursay_immudb_test_data
# Optional: EVM anchor signer private key (hex, 0x-prefixed). If unset, the anchor
# test generates an ephemeral secp256k1 key. In production this signing is delegated
# to the Turnkey wallet (see ../turnkey-test) using the same secp256k1 curve.
ANCHOR_SIGNER_PRIVKEY=
