{
  "name": "@oursay/web-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OurSay civic web app (Next.js App Router). Recreates the mobile wireframe's read model in full colour. Mock-backed frontend API today; swappable for /v1/public/... later.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.2",
    "vitest": "^4.1.9"
  }
}
